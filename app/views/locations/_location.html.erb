<div id="<%= dom_id location %>">
  <p>
    <strong>Address:</strong>
    <%= location.address %>
  </p>

  <p>
    <strong>Lat:</strong>
    <%= location.lat %>
  </p>

  <p>
    <strong>Long:</strong>
    <%= location.long %>
  </p>

  <p>
    <strong>Name:</strong>
    <%= location.name %>
  </p>

  <p>
    <strong>Link:</strong>
    <%= location.link %>
  </p>

</div>
